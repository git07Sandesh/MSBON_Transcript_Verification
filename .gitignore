# ── Secrets ─────────────────────────────────────────────────────────────
# Every .env / .env.local / .env.<env> file. Templates (.env.example) ARE
# tracked so developers know what shape is expected.
.env
.env.local
.env.*.local
**/.env
**/.env.local
**/.env.*.local
!**/.env.example
!**/.env.sample
*.pem
*.key

# ── macOS / editors ─────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

# ── Python ──────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
.tox/
*.egg-info/
*.egg
.venv/
venv/
env/
.python-version

# ── Node / Vite ─────────────────────────────────────────────────────────
node_modules/
dist/
dist-ssr/
.vite/
*.local
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── App-specific runtime artifacts ──────────────────────────────────────
msbon-app/backend/data/
msbon-app/backend/uploads/
msbon-app/backend/logs/*.log
msbon-app/backend/sqlite:/

# ── Pandoc / Chrome render scratch ──────────────────────────────────────
_sdd_tmp.html
_srd_tmp.html

# ── Misc ────────────────────────────────────────────────────────────────
*.log
.cache/
