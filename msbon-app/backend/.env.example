# MSBON Backend — Required Environment Variables
# Copy this file to .env and fill in all values before running.
# NEVER commit .env to version control.

# Google Gemini LLM integration (required, min 10 chars).
# For production, paste a real Gemini key here.
# For local demo without a key, use any value starting with "mock-"
# (e.g. mock-demo-key-for-poc-dev) and the system routes extraction
# through MockLLMAdapter instead of calling Google.
GEMINI_API_KEY=mock-demo-key-for-poc-dev

# Gemini model name
GEMINI_MODEL=gemini-2.0-flash

# JWT authentication secret (required, min 32 chars)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=

# Field-level PII encryption key (required, min 32 chars)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
ENCRYPTION_KEY=

# Database
DATABASE_URL=sqlite:///./data/msbon.db

# File storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10
FILE_RETENTION_HOURS=24

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Sentry DSN for error tracking (optional — leave empty to disable)
SENTRY_DSN=

# Runtime environment: development, staging, production
ENVIRONMENT=development

# App version
APP_VERSION=1.0.0-poc
